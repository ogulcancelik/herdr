# direnv: load the Nix devShell (guardrails toolbelt + herdr toolchain) on cd.
# The devShell's shellHook auto-runs `prek install`, so the governance hooks
# wire themselves the first time you enter the tree.
#
# guardrails owns the hooks via the standard .git/hooks path; if a previous
# `just install-hooks` pointed core.hooksPath at the old .githooks dir, clear
# it so prek installs where its bootstrap expects.
git config --local --get core.hooksPath >/dev/null 2>&1 && git config --local --unset-all core.hooksPath
use flake
