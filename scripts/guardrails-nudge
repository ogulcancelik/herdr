#!/usr/bin/env bash
# Run a guardrails gate as a non-blocking *nudge*: report any violations but
# never fail the commit. Used during the warn-only rollout while the existing
# debug-print / placeholder sites get cleaned up incrementally.
#
# To promote a gate to hard-blocking, point its `.pre-commit-config.yaml`
# entry straight at `guardrails-<name>` instead of this wrapper.
#
# Usage (from .pre-commit-config.yaml):  scripts/guardrails-nudge <gate-name> [files...]
set -uo pipefail

gate="${1:-}"
shift || true
if [ -z "$gate" ]; then
  echo "guardrails-nudge: missing gate name" >&2
  exit 0
fi

if ! "guardrails-$gate" "$@"; then
  echo "::guardrails nudge:: '$gate' flagged the above — warn-only, not blocking this commit." >&2
  echo "::guardrails nudge:: clean it up, or annotate the line with 'guardrails-ok' to suppress." >&2
fi
exit 0
